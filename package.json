{
  "name": "discord-crosspost-auto-translate",
  "version": "2.0.0",
  "description": "Automatically translates and replies to cross-posted messages.",
  "homepage": "https://github.com/tomacheese/discord-crosspost-auto-translate",
  "bugs": {
    "url": "https://github.com/tomacheese/discord-crosspost-auto-translate/issues"
  },
  "license": "MIT",
  "author": "Tomachi <tomachi@tomacheese.com>",
  "private": true,
  "main": "dist/main.js",
  "repository": {
    "type": "git",
    "url": "git@github.com:tomacheese/discord-crosspost-auto-translate.git"
  },
  "scripts": {
    "lint:prettier": "prettier --check src",
    "dev": "tsx watch ./src/main.ts",
    "lint:tsc": "tsc",
    "lint:eslint": "eslint . -c eslint.config.mjs",
    "test": "jest --runInBand --passWithNoTests --detectOpenHandles --forceExit",
    "fix:eslint": "eslint . -c eslint.config.mjs --fix",
    "lint": "run-z lint:prettier,lint:eslint,lint:tsc",
    "start": "tsx ./src/main.ts",
    "fix:prettier": "prettier --write src",
    "fix": "run-z fix:prettier fix:eslint",
    "compile": "tsc -p .",
    "clean": "rimraf dist output",
    "packing": "ncc build dist/main.js -o output",
    "package": "run-z clean compile packing",
    "generate-schema": "typescript-json-schema --required src/config.ts ConfigInterface -o schema/Configuration.json"
  },
  "devDependencies": {
    "@book000/eslint-config": "1.14.30",
    "@book000/node-utils": "1.24.170",
    "@types/jest": "30.0.0",
    "@types/node": "24.12.3",
    "@vercel/ncc": "0.38.4",
    "discord.js": "14.26.4",
    "eslint": "10.3.0",
    "eslint-config-standard": "17.1.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-n": "18.0.1",
    "eslint-plugin-promise": "7.3.0",
    "jest": "30.4.1",
    "jest-expect-message": "1.1.3",
    "prettier": "3.8.3",
    "rimraf": "6.1.3",
    "run-z": "2.1.0",
    "ts-jest": "29.4.9",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-json-schema": "0.67.2"
  },
  "jest": {
    "setupFilesAfterEnv": [
      "jest-expect-message"
    ],
    "moduleFileExtensions": [
      "js",
      "ts"
    ],
    "testMatch": [
      "**/*.test.ts"
    ],
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.json"
        }
      ]
    }
  },
  "packageManager": "pnpm@11.0.8+sha512.4c4097e1dd2d42372c4e7fa5a791ff28fc75a484c7ac192e64b1df0fdef17594ba982f9b4fed9adfb3c757846f565b799b2763fb3733d1de1bcb82cf46684912"
}
